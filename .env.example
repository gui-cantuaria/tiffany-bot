# === Required ===
DISCORD_TOKEN=your_discord_token
OPENROUTER_API_KEY=your_openrouter_key
CANAL_NOTICIAS_ID=your_news_channel_id
ID_CARGO_PARA_MARCAR=your_news_role_id
GUILD_ID=your_guild_id

# === Lavalink (só com servidor Lavalink rodando — docker-compose) ===
# Na VPS com systemd, deixe LAVALINK_ENABLED=0 para usar voz/Alexa (voice_recv).
# LAVALINK_ENABLED=0
# LAVALINK_HOST=lavalink
# LAVALINK_PORT=2333
# LAVALINK_PASSWORD=tiffany_lavalink_2026

# === Voice (optional) ===
# VOICE_ENABLED=1
# DM: require user to share at least one server with the bot (default 1). Set 0 to allow any DM.
# DM_REQUIRE_SHARED_GUILD=1
# Rejoin voice channel automatically after bot restart (default 0 — use t!p to play again)
# VOICE_AUTO_REJOIN=0
# TTS_ENABLED=1
# STT_GEMINI_FALLBACK=1
# Primary STT: Whisper via OpenRouter (see docs/voice-technical.md)
# STT_OPENROUTER_MODEL=openai/whisper-large-v3
# Fallback chat STT when Whisper fails or wake word missing
# STT_CHAT_MODEL=google/gemini-3.1-flash-lite
# Save last captured WAV to /tmp/tiffany_debug_audio.wav for STT debugging
# DEBUG_STT=1
# FFMPEG_PATH=
# VOICE_CONNECT_TIMEOUT_SEC=25

# === WARP proxy (VPS only — required for YouTube/yt-dlp) ===
# YouTube blocks datacenter IPs. Install once: bash scripts/warp-setup.sh
# SOCKS5 proxy at 127.0.0.1:40000 (hardcoded in tiffany_voice YDL_OPTS).
# Healthcheck timer tiffany-warp-healthcheck reconnects if proxy drops.
# News/offers still start if WARP is down; music commands fail without it.

# === Dice (optional) ===
# DICE_CHANNELS=123456789,987654321
# Delete @rollem-next replies in dice channels (needs Manage Messages). 0 = off
# DICE_DELETE_ROLLEM=1
# Also delete classic @rollem (240732567744151553)
# ROLLEM_DELETE_ALL=0
# Custom bot IDs (replaces default): ROLLEM_DELETE_BOT_IDS=840409146738475028

# === Offers (optional) ===
# CANAL_OFERTAS_ID=1512902840908124281
# ID_CARGO_OFERTAS=1386386059390357575

# === Affiliate (all optional) ===
# AMAZON_AFFILIATE_TAG=
# MERCADOLIVRE_AFFILIATE_ID=
# AWIN_PUBLISHER_ID=
# MAGALU_LOJA_SLUG=
# TERABYTE_AFFILIATE_ID=
# SHOPINFO_AFFILIATE_ID=
# SHOPINFO_PARAM_NAME=
# ALIEXPRESS_AFFILIATE_ID=
# LOMADEE_APP_TOKEN=
# LOMADEE_SOURCE_ID=
